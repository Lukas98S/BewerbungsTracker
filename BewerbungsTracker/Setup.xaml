<UserControl x:Class="BewerbungsTracker.Setup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#F5F5F5">
    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Width="350">
        <TextBlock Text="Willkommen beim Bewerbungs-Tracker!" FontSize="18" FontWeight="Bold" Margin="0,0,0,15" TextAlignment="Center"/>
        <TextBlock Text="Bitte richte einmalig dein E-Mail-Postfach ein, damit wir Absagen im Hintergrund autommatisch erkennen können." TextWrapping="Wrap" Margin="0,0,0,25" TextAlignment="Center"/>

        <TextBlock Text="E-Mail Adresse:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15" Height="25" Padding="2"/>

        <TextBlock Text="Passwort:" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox Text="{Binding Passwort}" Margin="0,0,0,15" Height="25" Padding="2"/>

        <TextBlock Text="IMAP-Server (Wird oft automatisch erkannt):" FontWeight="Bold" Margin="0,0,0,5"/>
        <TextBox Text="{Binding ImapServer}" Margin="0,0,0,25" Height="25" Padding="2"/>

        <Button Content="Daten Speichern &amp; Starten" Command="{Binding SaveCommand}" Height="40" Background="#4CAF50" Foreground="White" FontWeight="Bold" FontSize="14"/>
    </StackPanel>
</Grid>
</UserControl>

<Window x:Class="BewerbungsTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BewerbungsTracker"
        mc:Ignorable="d"
        Title="" Height="450" Width="800"
        Icon="Image/Logo.png">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <DataTemplate DataType="{x:Type local:SetupViewModel}">
            <local:Setup />
        </DataTemplate>
        
        <DataTemplate DataType="{x:Type local:BewerberAnsichtViewModel}">
            <local:BewerberAnsicht />
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:ArchivAnsichtViewModel}">
            <local:ArchivAnsicht />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#21212E">
            <StackPanel Margin="0,30,0,0" Visibility="{Binding MenuVisible, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="Bewerbungs-Tracker" Foreground="White" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,40"/>
                <Button x:Name="BtnAktive" Content="Aktive Bewerbungen" Command="{Binding ZeigeAktiveCommand}"
                        Height="45" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="15" Margin="10,5"/>
                <Button x:Name="BtnArchiv" Content="Archiv &amp; Absagen" Command="{Binding ZeigeArchivCommand}"
                         Height="45" Background="Transparent" Foreground="White" BorderThickness="0" FontSize="15" Margin="10,5"/>
            </StackPanel>
        </Border>

        <ContentControl Content="{Binding AktuelleAnsicht}" Grid.Column="1" Background="#F5F5F5"/>
    </Grid>
</Window>
